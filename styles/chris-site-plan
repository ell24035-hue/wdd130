@font-face {
  font-family: arial;
  src: url();
}




/* if you are using any Google fonts change the font names below to your fonts. 
Any spaces in your font name should be replaced with a +. 
Fonts are separated by a & */
@import url('https://fonts.googleapis.com/css2?family=IM+Fell+French+Canon&family=Lato:ital,wght@0,400;0,700;1,400&display=swap');

:root {
  /* change the values below to your colors from your palette */
  --primary-color: #401F3E   ;
  --secondary-color: #3F2E56 ;
  --accent1-color: #453F78;
  --accent2-color: #759AAB;

  /* change the values below to your chosen font(s) */
  --heading-font: "IM Fell French Canon";
  --paragraph-font: Arial, sans-serif, Helvetica;

  /* these colors below should be chosen from among your palette colors above */
  --headline-color-on-white: #251605;  /* headlines on a white background */ 
  --headline-color-on-color: #98c1d2; /* headlines on a colored background */ 
  --paragraph-color-on-white: #251605; /* paragraph text on a white background */ 
  --paragraph-color-on-color: #98c1d2; /* paragraph text on a colored background */ 
  --paragraph-background-color: #251605  ;
  --nav-link-color: #251605;
  --nav-background-color: #F1AB86;
  --nav-hover-link-color: #9CAFB7;
  --nav-hover-background-color: #251605;
}
